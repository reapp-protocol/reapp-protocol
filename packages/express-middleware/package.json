{
  "name": "@reapp-sdk/express-middleware",
  "version": "0.2.1",
  "description": "Fail-closed Express middleware for REAPP x402 APIs with independent on-chain settlement verification.",
  "keywords": [
    "reapp",
    "express",
    "middleware",
    "x402",
    "stellar",
    "soroban",
    "agent-payments",
    "payment-verification"
  ],
  "type": "module",
  "main": "./dist/index.js",
