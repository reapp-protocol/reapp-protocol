# Copy to .env (which is git-ignored). NEVER commit real keys.
# These are HOT TESTNET keys only — never reuse on mainnet.

# Stellar testnet
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# BIP39 seed phrase (SEP-0005). Keypairs are DERIVED from this:
#   `npm run key`        -> account index 0  (the user / mandate signer)
#   `npm run key -- 1`   -> account index 1  (the agent)
# HOT TESTNET ONLY. Never reuse this phrase on mainnet. Never commit .env.
MNEMONIC="word word word word word word word"

# Derived secrets (optional cache; prefer deriving on demand via `npm run key`)
USER_SECRET=S...
AGENT_SECRET=S...

# Deployed contract + asset (filled after deploy)
MANDATE_REGISTRY_CONTRACT_ID=
USDC_SAC_CONTRACT_ID=


REAPP_BURNER_PUBLIC_KEY=G...your-burner-address...
REAPP_BURNER_SECRET_KEY=S...your-burner-secret...