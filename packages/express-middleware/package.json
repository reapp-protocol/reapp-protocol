      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test src/middleware.test.ts src/bound.test.ts src/bound-route.test.ts src/verification.test.ts"
  },
  "dependencies": {
    "@reapp-sdk/core": "^0.3.0",
