{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "packages/stellar/src/**/*",
    "packages/sdk/src/**/*",
    "packages/ap2/src/**/*",
    "packages/cli/src/**/*"
  ],
  "exclude": ["**/*.test.ts"]
}
