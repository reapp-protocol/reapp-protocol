{
  "name": "reapp-protocol",
  "version": "0.0.0",
  "private": true,
  "description": "Agent-driven payments: AP2 mandates enforced on-chain by Soroban via x402.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w @reapp-sdk/stellar && npm run build -w @reapp-sdk/core && npm run build --workspaces --if-present",
    "cli:bundle": "esbuild packages/cli/src/index.ts --bundle --platform=node --format=esm --target=node20 --external:@stellar/stellar-sdk --banner:js=\"import{createRequire as __cr}from'module';const require=__cr(import.meta.url);\" --outfile=packages/cli/dist/reapp-cli.bundle.mjs",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "tsc",
    "verify": "node scripts/verify.mjs",
    "demo": "node scripts/e2e-testnet.mjs",
    "keys:derive-freighter": "node scripts/derive-freighter.mjs",
    "deploy:testnet": "node scripts/deploy.mjs",
    "e2e:testnet": "node scripts/e2e-testnet.mjs",
    "e2e:composites": "node scripts/e2e-composites.mjs",
    "e2e:sdk": "node scripts/e2e-sdk.mjs",
    "e2e:x402": "tsx scripts/e2e-x402.ts",
    "gatecheck": "node scripts/gatecheck-mandate.mjs"
  },
  "devDependencies": {
    "@stellar/stellar-sdk": "^14.6.1",
    "@types/node": "^22.10.2",
    "dotenv": "^16.4.7",
    "playwright": "^1.60.0",
    "stellar-hd-wallet": "^0.0.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@reapp-sdk/core": "^0.2.2"
  }
}
