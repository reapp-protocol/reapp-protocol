    "@stellar/stellar-sdk": "^14.5.0",
    "buffer": "6.0.3"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/express": "^5.0.6",
    "express": "^5.2.1",
    "typescript": "^5.7.2"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
